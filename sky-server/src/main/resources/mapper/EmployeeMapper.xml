<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    MyBatis XML映射文件
    namespace - 必须与Mapper接口的全限定名一致，用于关联接口和SQL
-->
<mapper namespace="com.sky.mapper.EmployeeMapper">
    <!--
        select - 查询语句
        id - 必须与Mapper接口中的方法名一致
        resultType - 指定返回结果类型(实体类的全限定名或别名)
        #{username} - MyBatis参数占位符，会自动替换为方法的参数值
    -->
    <select id="getByUsername" resultType="Employee">
        SELECT * FROM employee WHERE username = #{username}
    </select>

    <!--
        insert - 新增语句
        id - 必须与Mapper接口中的方法名一致
        #{字段名} - 对应Employee实体类的属性名，MyBatis自动映射
    -->
    <insert id="save">
        INSERT INTO employee (name, username, password, phone, sex, id_number, status, create_time, update_time, create_user, update_user)
            VALUES (#{name}, #{username}, #{password}, #{phone}, #{sex}, #{idNumber}, #{status}, #{createTime}, #{updateTime}, #{createUser}, #{updateUser})
    </insert>

    <!--
        分页查询（配合PageHelper，会自动追加LIMIT）
        <where> - 自动处理WHERE和AND/OR前缀
        <if> - 条件成立才拼接SQL
        concat('%', #{name}, '%') - 模糊查询拼接通配符
    -->
    <select id="page" resultType="Employee">
        SELECT * FROM employee
        <where>
            <if test="name != null and name != ''">
                name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY update_time DESC
    </select>

    <!--
        动态更新语句
        <set> - 自动添加SET关键字，并去除末尾多余的逗号
        <if> - 条件成立才拼接该字段
        注意：String类型用 != '' 判断空字符串，Integer/LocalDateTime类型只判断 != null
    -->
    <update id="update">
        UPDATE employee
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="sex != null and sex != ''">
                sex = #{sex},
            </if>
            <if test="idNumber != null and idNumber != ''">
                id_number = #{idNumber},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="createUser != null">
                create_user = #{createUser},
            </if>
            <if test="updateUser != null">
                update_user = #{updateUser}
            </if>
        </set>
        WHERE id = #{id}
    </update>

        <!-- 根据id查询员工 -->
    <select id="getById" resultType="Employee">
        SELECT * FROM employee WHERE id = #{id}
    </select>
</mapper>